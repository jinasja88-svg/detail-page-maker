{
  "manifest_version": 3,
  "name": "상세페이지 이미지 추출기",
  "version": "1.0.0",
  "description": "쿠팡/네이버/카페24 상세페이지 이미지를 추출합니다",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://*.coupang.com/*",
    "https://*.naver.com/*",
    "https://*.cafe24.com/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.coupang.com/*",
        "https://*.naver.com/*",
        "https://*.cafe24.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
