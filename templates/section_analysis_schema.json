{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input_index",
          "role",
          "copy_text",
          "copy_score",
          "design_score",
          "core_message"
        ],
        "properties": {
          "input_index": {
            "type": "integer"
          },
          "role": {
            "type": "string",
            "enum": [
              "HOOK",
              "PAIN",
              "SOLUTION",
              "FEATURE",
              "BENEFIT",
              "SOCIAL_PROOF",
              "HOW_TO",
              "COMPARE",
              "INGREDIENT",
              "BRAND",
              "GUARANTEE",
              "BUNDLE",
              "CTA",
              "FILLER"
            ]
          },
          "copy_text": {
            "type": "string"
          },
          "copy_score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "design_score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "core_message": {
            "type": "string"
          }
        }
      }
    }
  }
}
